# ─── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────
dist/
dist-ssr/
build/
*.tsbuildinfo

# ─── Environment Variables (NEVER commit secrets) ─────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Python / FastAPI ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
.Python

# ─── Docker ───────────────────────────────────────────────────
# (docker-compose.yml is fine to commit, but not local overrides)
docker-compose.override.yml

# ─── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ─── Coverage / Test ──────────────────────────────────────────
coverage/
.nyc_output/
