# ============================================================
# FinFolio — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=finfolio
POSTGRES_PASSWORD=finfolio_secret
POSTGRES_DB=finfolio_db

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── AlphaVantage (optional, for live market data) ───────────
ALPHAVANTAGE_API_KEY=demo

# ── Service URLs (used locally outside Docker) ──────────────
DATABASE_URL=postgresql://finfolio:finfolio_secret@localhost:5432/finfolio_db
REDIS_URL=redis://:redis_secret@localhost:6379
ANALYTICS_URL=http://localhost:8000
VITE_API_URL=http://localhost:3001
VITE_ANALYTICS_URL=http://localhost:8000
